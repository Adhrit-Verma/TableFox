# PostgreSQL connection. Use a dedicated read-only role.
# Configure either DATABASE_URL or the PG* variables, not both.
# DATABASE_URL=postgresql://readonly_user:replace_with_password@db.example.com:5432/database_name?sslmode=require

PGHOST=db.example.com
PGPORT=5432
PGDATABASE=database_name
PGUSER=readonly_user
PGPASSWORD=replace_with_password
PGSSLMODE=require

# Backend/API settings
DBMAP_CACHE_DIR=.dbmap-cache
DBMAP_STATEMENT_TIMEOUT_MS=5000
DBMAP_MAX_QUERY_ROWS=200
DBMAP_API_HOST=127.0.0.1
DBMAP_API_PORT=8000

# Frontend settings
NEXT_PUBLIC_DBMAP_API_URL=/dbmap-api
