# PostgreSQL connection. Use a dedicated read-only role.
# Configure either DATABASE_URL or the PG* variables, not both.
# DATABASE_URL=postgresql://readonly_user:replace_with_password@db.example.com:5432/database_name?sslmode=require

PGHOST=db.example.com
PGPORT=5432
PGDATABASE=database_name
PGUSER=readonly_user
PGPASSWORD=replace_with_password
PGSSLMODE=require

# Backend/API settings
DBMAP_CACHE_DIR=.dbmap-cache
DBMAP_STATEMENT_TIMEOUT_MS=5000
DBMAP_MAX_QUERY_ROWS=200
DBMAP_MAX_EXPLAIN_COST=100000
DBMAP_MAX_EXPLAIN_ROWS=100000
# Result columns with common credential/PII names are blocked unless an operator opts in.
DBMAP_ALLOW_SENSITIVE_DATA=false
# Empty means all visible schemas. Restricted schemas always take precedence.
DBMAP_ALLOWED_SCHEMAS=public
DBMAP_RESTRICTED_SCHEMAS=
# Reads aggregate pg_stat_user_tables counters only; never query text.
DBMAP_ENABLE_USAGE_TELEMETRY=false
DBMAP_CONTEXT_FILE=.tablefox-context.json
DBMAP_BASELINE_FILE=.dbmap-cache/baseline.snapshot.json
DBMAP_AUDIT_DIR=.logs/audit
DBMAP_AUDIT_RETENTION_DAYS=30
# Set true only after creating tablefox-auth.json with dbmap-create-key.
DBMAP_AUTH_REQUIRED=false
DBMAP_AUTH_FILE=tablefox-auth.json
DBMAP_MCP_ACTOR=local-mcp
DBMAP_API_HOST=127.0.0.1
DBMAP_API_PORT=8000

# Frontend settings
NEXT_PUBLIC_DBMAP_API_URL=/dbmap-api
