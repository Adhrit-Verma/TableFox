# PostgreSQL connection. Use a read-only role for normal operation.
# DATABASE_URL takes precedence when set.
DATABASE_URL=postgresql://dbmap_reader:change-me-demo-only@localhost:55432/dbmap_demo

# Alternative PG* variables, used when DATABASE_URL is not set.
PGHOST=localhost
PGPORT=55432
PGDATABASE=dbmap_demo
PGUSER=dbmap_reader
PGPASSWORD=change-me-demo-only
PGSSLMODE=prefer

# Backend/API settings
DBMAP_CACHE_DIR=.dbmap-cache
DBMAP_STATEMENT_TIMEOUT_MS=5000
DBMAP_MAX_QUERY_ROWS=200
DBMAP_API_HOST=127.0.0.1
DBMAP_API_PORT=8000

# Frontend settings
NEXT_PUBLIC_DBMAP_API_URL=http://127.0.0.1:8000
